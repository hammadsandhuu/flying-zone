  "homeAbout": {
    "subtitle": "Who We Are",
    "title": "Your Trusted Travel Companion",
    "description": "At Flying Zone, we simplify your global travel dreams with expert care. Established in 2007, our legacy of excellence now extends across the UAE and Pakistan. From sacred pilgrimages to luxury holidays, we provide seamless solutions tailored to your needs. Experience world-class hospitality, competitive pricing, and a commitment to making every journey unforgettable and stress-free.",
    "facilities": [
      {
        "id": 1,
        "title": "Safety First Always",
        "description": "We prioritize your security with verified bookings and 24/7 support for all international travels.",
        "isSecondary": false
      },
      {
        "id": 2,
        "title": "Trusted Travel Guide",
        "description": "Our 17+ years of industry expertise ensures you receive the most reliable advice and visa assistance.",
        "isSecondary": true
      },
      {
        "id": 3,
        "title": "Time and Stress Savings",
        "description": "Let our experts handle the paperwork while you enjoy a smooth, hassle-free booking experience.",
        "isSecondary": false
      }
    ],
